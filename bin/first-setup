#!/usr/bin/env bash
#
# Bootstrap a new Mac:
#   1. Install Homebrew (if missing)
#   2. Install everything in config/homebrew/Brewfile
#   3. Clone the private dotfiles repo (only for the personal account)
#   4. Run dotbot for the public repo
#   5. Run dotbot for the private repo (if present)
#   6. Apply macOS defaults

set -e

# Colors
BLUE='\033[0;34m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

step() { echo ""; echo -e "${BLUE}➜${NC} $1"; }
success() { echo -e "${GREEN}✓${NC} $1"; }
warn() { echo -e "${YELLOW}⚠${NC} $1"; }
error() { echo -e "${RED}✗${NC} $1"; exit 1; }

BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PRIVATE_REPO="stefanzweifel/dotfiles-private"
PRIVATE_DIR="${HOME}/.dotfiles-private"

echo ""
step "First-time dotfiles setup"
echo ""
warn "This will install Homebrew + packages, link dotfiles, and apply macOS defaults."
echo ""
read -p "Continue? (y/n) " -n 1 -r
echo ""
if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    echo "Aborted."
    exit 0
fi

# 1. Homebrew
step "Checking for Homebrew"
if ! command -v brew >/dev/null 2>&1; then
    warn "Homebrew not found — installing"
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

    # Add brew to PATH for the remainder of this script
    if [ -x /opt/homebrew/bin/brew ]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
    elif [ -x /usr/local/bin/brew ]; then
        eval "$(/usr/local/bin/brew shellenv)"
    fi
fi
success "Homebrew ready"

# 2. Brewfile
step "Installing packages from Brewfile"
brew bundle --file="${BASEDIR}/config/homebrew/Brewfile"
success "Brewfile packages installed"

# 3. Private dotfiles — only for the personal GitHub account
step "Checking for private dotfiles repo"
if command -v gh >/dev/null 2>&1 && gh auth status >/dev/null 2>&1; then
    login=$(gh api user --jq .login 2>/dev/null || echo "")
    if [ "$login" = "stefanzweifel" ]; then
        if [ ! -d "${PRIVATE_DIR}" ]; then
            step "Cloning ${PRIVATE_REPO} into ${PRIVATE_DIR}"
            gh repo clone "${PRIVATE_REPO}" "${PRIVATE_DIR}"
            success "Private dotfiles cloned"
        else
            success "Private dotfiles already present at ${PRIVATE_DIR}"
        fi
    else
        warn "GitHub user is '${login}' (not stefanzweifel) — skipping private repo"
    fi
else
    warn "gh not authenticated — skipping private repo. Run 'gh auth login' and re-run if needed."
fi

# 4. Dotbot — public
step "Linking dotfiles (public)"
"${BASEDIR}/bin/install"
success "Public dotfiles linked"

# 5. Dotbot — private
if [ -x "${PRIVATE_DIR}/bin/install" ]; then
    step "Linking dotfiles (private)"
    "${PRIVATE_DIR}/bin/install"
    success "Private dotfiles linked"
fi

# 6. macOS defaults
step "Applying macOS defaults"
"${BASEDIR}/bin/macos-defaults"

echo ""
success "First-time setup complete!"
echo ""
warn "Restart your terminal (or run: exec zsh) to pick up new shell config."
echo ""
