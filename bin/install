#!/usr/bin/env bash

set -e

CONFIG="install.conf.yml"
DOTBOT_DIR="dotbot"

DOTBOT_BIN="bin/dotbot"
BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "${BASEDIR}/bin/_helpers.sh"

dotfiles_header

cd "${BASEDIR}"

step "Updating dotbot submodule"
git submodule update --init --recursive "${DOTBOT_DIR}"
success "Submodule up to date"

step "Linking dotfiles"
"${BASEDIR}/${DOTBOT_DIR}/${DOTBOT_BIN}" -d "${BASEDIR}" -c "${CONFIG}" "${@}"
success "Dotfiles linked"

step "Installing git-trim"
GIT_TRIM_DIR="${HOME}/.local/share/git-trim"
GIT_TRIM_BIN="${HOME}/.local/bin/git-trim"
mkdir -p "${HOME}/.local/bin"
if [ -d "${GIT_TRIM_DIR}/.git" ]; then
    git -C "${GIT_TRIM_DIR}" pull --ff-only --quiet
else
    git clone --quiet https://github.com/jasonmccreary/git-trim.git "${GIT_TRIM_DIR}"
fi
ln -sf "${GIT_TRIM_DIR}/git-trim" "${GIT_TRIM_BIN}"
success "git-trim installed at ${GIT_TRIM_BIN}"
